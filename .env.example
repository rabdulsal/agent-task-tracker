# ── Required ──────────────────────────────────────────────────────────────────
API_KEY=your-secret-api-key-here          # agents send this in x-api-key header
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
ALERT_EMAIL=you@example.com               # where daily reports are sent

# ── Optional ──────────────────────────────────────────────────────────────────
FROM_EMAIL=tasks@yourdomain.com           # defaults to tasks@webslingerai.com
API_BASE_URL=https://your-render-url.onrender.com
DB_PATH=./data/tasks.db                   # defaults to ./data/tasks.db
PORT=3000
